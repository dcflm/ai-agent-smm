# ── Copy this to .env and fill in your values ────────────────────────────────

# Anthropic Claude (required)
ANTHROPIC_API_KEY=sk-ant-...

# Nano Banana — AI image generation (optional, images skipped if blank)
NANO_BANANA_API_KEY=

# Supabase — database + vector search (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# Tavily — news search (optional, skipped if blank)
TAVILY_API_KEY=tvly-...

# OpenAI — embeddings for RAG (optional)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# Email notifications via Resend (optional — enables "email me after scheduled generation")
# Get a key at resend.com. Without a verified domain, the default sender only delivers
# to your own Resend account email. The recipient address is set in the app (Schedule page).
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# LinkedIn — post publishing (optional, posts stay "approved" if not set)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000   # production: https://your-app.vercel.app
ENVIRONMENT=development
CLAUDE_MODEL=claude-sonnet-4-6
RAG_TOP_K=3
STYLE_RULES_LIMIT=10

# Legacy (Notion removed — keep blank)
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_WEBHOOK_SECRET=
